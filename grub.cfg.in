set timeout=5
set default=0

menuentry "UnDOS" {
    insmod fat
    
    multiboot /boot/undos-boot CMDLINE=12 root=PhysicalDiskQM00001Volume0
    module /boot/kernel.elf kernel_core
    module /boot/hal_x86_old.elf hal_x86_old
    module /boot/bus_isa.elf bus_isa
    module /boot/disk_ata.elf disk_ata
    module /boot/volmgr.elf volmgr
    module /boot/fs_fat.elf fs_fat
    boot
}
